# LLM Provider Configuration
# Choose 'openai' or 'gemini'
LLM_PROVIDER=openai

# API Keys (add your keys here)
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Model Configuration
MODEL_NAME=gpt-4
TEMPERATURE=0.7
MAX_TOKENS=1000

# API Base URL (Optional - for proxy or custom endpoints)
# Leave empty to use default URLs
# Examples:
#   OpenAI: https://api.openai.com/v1
#   DeepSeek: https://api.deepseek.com
#   本地代理: http://localhost:8080/v1
OPENAI_BASE_URL=
GEMINI_BASE_URL=

# Execution Settings
TIMEOUT_SECONDS=5
MAX_CODE_LENGTH=10000

# App Settings
DEBUG_MODE=false
